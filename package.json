{
  "name": "daily-bible-verse",
  "version": "0.9.0",
  "description": "Obsidian plugin: a daily Bible verse in your daily note as an elegant callout — no-repeat rotation, offline, five languages.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-data": "tsx scripts/fetch-verses.ts",
    "validate-refs": "tsx scripts/validate-refs.ts",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "bible",
    "daily-notes"
  ],
  "author": "polygonhunter",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.3",
    "tsx": "^4.16.0",
    "typescript": "~5.4.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "obsidian-daily-notes-interface": "^0.9.4"
  }
}
